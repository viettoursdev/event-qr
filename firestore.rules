// =====================================================================
//  RULES SỰ KIỆN — 2 block cần CHÈN THÊM vào Firestore Rules của project
//  tour-cost-calculator-4336c (KHÔNG xoá rules app tính giá).
//  Đặt 2 block này BÊN TRONG: match /databases/{database}/documents { ... }
//  ⚠️ App tính giá tự deploy rules riêng -> nên thêm 2 block này vào
//     firestore.rules của REPO app tính giá để mỗi lần deploy đều giữ.
// =====================================================================

// event_guests: danh sách khách + check-in/xác nhận (check-in app đọc)
match /event_guests/{id} {
  function isStaff() {
    return request.auth != null
      && request.auth.token.firebase.sign_in_provider == 'password';
  }
  function changed() {
    return request.resource.data.diff(resource.data).affectedKeys();
  }

  // Chỉ nhân viên (đăng nhập Email/Password) đọc được — bảo vệ SĐT
  allow read: if isStaff();

  allow update: if
    // Nhân viên: sửa trường check-in và/hoặc xác nhận (xác nhận hộ khách)
    (isStaff() && changed().hasOnly(['checkedIn', 'checkinAt', 'checkinBy', 'confirmed', 'confirmedAt', 'confirmedVia']))
    // Khách từ trang QR: chỉ sửa 3 trường xác nhận (KHÔNG cần đăng nhập)
    || changed().hasOnly(['confirmed', 'confirmedAt', 'confirmedVia']);

  // Thêm/xoá khách chỉ qua script admin (bỏ qua rules)
  allow create, delete: if false;
}

// event_public: dữ liệu hiển thị cho trang QR (tên/công ty/STT/bàn — KHÔNG SĐT)
match /event_public/{token} {
  allow get: if true;            // đọc 1 doc theo token (ai có QR riêng)
  allow list, write: if false;   // CẤM liệt kê + cấm ghi từ client
}
