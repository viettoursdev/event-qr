rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Danh sách khách + trạng thái check-in / xác nhận
    match /guests/{id} {
      // Nhân viên = đăng nhập bằng Email/Password
      function isStaff() {
        return request.auth != null
          && request.auth.token.firebase.sign_in_provider == 'password';
      }
      function changed() {
        return request.resource.data.diff(resource.data).affectedKeys();
      }

      // Chỉ nhân viên đọc được (bảo vệ SĐT) — khách ẩn danh KHÔNG đọc được danh sách
      allow read: if isStaff();

      allow update: if
        // Nhân viên: sửa trường check-in và/hoặc xác nhận (xác nhận hộ khách)
        (isStaff() && changed().hasOnly(['checkedIn', 'checkinAt', 'checkinBy', 'confirmed', 'confirmedAt', 'confirmedVia']))
        // Khách (đăng nhập ẩn danh từ trang QR): chỉ sửa 3 trường xác nhận
        || (request.auth != null && changed().hasOnly(['confirmed', 'confirmedAt', 'confirmedVia']));

      // Thêm/xoá khách chỉ làm qua script admin (bỏ qua rules)
      allow create, delete: if false;
    }
  }
}
