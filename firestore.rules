// =====================================================================
//  RULES SỰ KIỆN — 3 block cần CHÈN THÊM vào Firestore Rules của project
//  tour-cost-calculator-4336c (KHÔNG xoá rules app tính giá).
//  Đặt các block này BÊN TRONG: match /databases/{database}/documents { ... }
//  ⚠️ App tính giá tự deploy rules riêng -> nên thêm các block này vào
//     firestore.rules của REPO app tính giá để mỗi lần deploy đều giữ.
// =====================================================================

// event_guests: danh sách khách + check-in / xác nhận / ăn chay (check-in app đọc)
match /event_guests/{id} {
  function isStaff() {
    return request.auth != null
      && request.auth.token.firebase.sign_in_provider == 'password';
  }
  // Tài khoản CHỈ XEM: đăng nhập + đọc được, nhưng KHÔNG được ghi bất kỳ trường nào.
  function isViewer() {
    return request.auth != null
      && request.auth.token.email.lower() == 'checkin.viewonly@viettours.local';
  }
  function changed() {
    return request.resource.data.diff(resource.data).affectedKeys();
  }

  // Chỉ nhân viên (đăng nhập Email/Password) đọc được — bảo vệ SĐT
  allow read: if isStaff();

  // Tài khoản chỉ-xem bị chặn ghi hoàn toàn (kể cả nhánh khách QR, vì đã đăng nhập).
  allow update: if !isViewer() && (
    // Nhân viên: sửa trường check-in / xác nhận / ăn chay
    (isStaff() && changed().hasOnly(['checkedIn', 'checkinAt', 'checkinBy', 'confirmed', 'confirmedAt', 'confirmedVia', 'vegetarian', 'vegetarianVia', 'vegetarianAt']))
    // Khách từ trang QR: chỉ sửa trường xác nhận / ăn chay (KHÔNG cần đăng nhập)
    || changed().hasOnly(['confirmed', 'confirmedAt', 'confirmedVia', 'vegetarian', 'vegetarianVia', 'vegetarianAt'])
  );

  // Thêm/xoá khách chỉ qua script admin (bỏ qua rules)
  allow create, delete: if false;
}

// event_public: dữ liệu hiển thị cho trang QR (tên/danh xưng/công ty/STT/bàn — KHÔNG SĐT)
match /event_public/{token} {
  allow get: if true;            // đọc 1 doc theo token (ai có QR riêng)
  allow list, write: if false;   // CẤM liệt kê + cấm ghi từ client
}

// event_config: cờ khoá/mở chức năng. Chỉ tài khoản Admin được ghi.
match /event_config/{doc} {
  allow read: if request.auth != null
    && request.auth.token.firebase.sign_in_provider == 'password';
  allow write: if request.auth != null
    && request.auth.token.email.lower() == 'checkin.admin@viettours.local';
}
